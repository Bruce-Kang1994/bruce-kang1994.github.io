---
import BaseLayout from './BaseLayout.astro';
import '../styles/lab.css';
import TOC from '../components/TOC.astro';
import { categoryColors, formatDate, readingTime, slugify, withBase } from '../lib/utils';
import { translations } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  date: Date;
  headings: { depth: number; slug: string; text: string }[];
  body: string;
  relatedPosts?: { title: string; slug: string; category: string }[];
}

const { title, description, category, tags, date, headings, body, relatedPosts = [] } = Astro.props;
const url = (path: string) => withBase(path, '/lab');
const catLabel = translations.zh.category[category as keyof typeof translations.zh.category]?.label || category;
const mins = readingTime(body);
const tone = categoryColors[category] ?? categoryColors.frameworks;
---

<BaseLayout title={title} description={description} section="lab">
  <div class="max-w-[1160px] mx-auto px-6 py-10 sm:py-16">
    <!-- Header -->
    <header class="max-w-[760px] mb-12">
      <div class="eyebrow mb-5">Field Note</div>
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mb-4 text-[13px] text-[rgb(var(--text-3))]">
        <a href={url(`${category}/`)} class:list={['inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[12px] font-semibold hover:opacity-80 transition-opacity', tone.bg, tone.text, tone.border]} data-i18n={`category.${category}.label`}>
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-current opacity-70"></span>
          {catLabel}
        </a>
        <span>&middot;</span>
        <span data-locale-date data-date={date.toISOString()}>{formatDate(date)}</span>
        <span>&middot;</span>
        <span data-locale-mins data-mins={mins}>{mins} 分钟阅读</span>
      </div>

      <h1 class="display-serif text-[36px] sm:text-[48px] font-bold leading-[1.08] tracking-[-0.04em] mb-5">
        {title}
      </h1>

      <p class="text-[17px] text-[rgb(var(--text-2))] leading-relaxed max-w-[42rem]">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-6">
          {tags.map((tag) => (
            <a href={url(`tags/${slugify(tag)}/`)}
              class="tag-pill">
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- Content + TOC -->
    <div class="flex gap-16 xl:gap-20">
      <article class="prose flex-1 min-w-0">
        <slot />
      </article>
      <TOC headings={headings} />
    </div>

    <!-- Related -->
    {relatedPosts.length > 0 && (
      <section class="max-w-[760px] mt-20 pt-8 border-t border-[rgb(var(--border))]">
        <h3 class="section-kicker mb-5" data-i18n="article.related">相关文章</h3>
        <div class="space-y-0">
          {relatedPosts.map((post) => {
            const rl = translations.zh.category[post.category as keyof typeof translations.zh.category]?.label;
            return (
              <a href={url(`posts/${post.slug}/`)} class="group flex items-center justify-between py-4 border-b border-[rgb(var(--border))] last:border-b-0">
                <div>
                  <span class="text-[12px] text-[rgb(var(--text-3))]" data-i18n={`category.${post.category}.label`}>{rl}</span>
                  <h4 class="text-[17px] font-medium tracking-[-0.02em] group-hover:text-[rgb(var(--accent))] transition-colors">{post.title}</h4>
                </div>
                <svg class="w-4 h-4 shrink-0 text-[rgb(var(--text-3))] opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
