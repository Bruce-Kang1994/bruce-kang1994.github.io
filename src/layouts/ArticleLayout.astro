---
import BaseLayout from './BaseLayout.astro';
import '../styles/lab.css';
import TOC from '../components/TOC.astro';
import { categoryColors, formatDate, readingTime, slugify, withBase } from '../lib/utils';
import { translations } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  date: Date;
  headings: { depth: number; slug: string; text: string }[];
  body: string;
  relatedPosts?: { title: string; slug: string; category: string }[];
}

const { title, description, category, tags, date, headings, body, relatedPosts = [] } = Astro.props;
const url = (path: string) => withBase(path, '/lab');
const catLabel = translations.zh.category[category as keyof typeof translations.zh.category]?.label || category;
const catLabelEn = translations.en.category[category as keyof typeof translations.en.category]?.label || category;
const mins = readingTime(body);
const tone = categoryColors[category] ?? categoryColors.frameworks;
---

<BaseLayout title={title} description={description} section="lab">
  <div class="max-w-[1080px] mx-auto px-6 py-10 sm:py-16">
    <!-- Header -->
    <header class="max-w-[720px] mb-10">
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mb-4 text-[12px] text-[var(--text-3)]">
        <a href={url(`${category}/`)} class:list={['inline-flex items-center gap-1 rounded border px-2 py-0.5 text-[11px] font-semibold hover:opacity-80 transition-opacity', tone.bg, tone.text, tone.border]} data-copy-zh={catLabel} data-copy-en={catLabelEn}>
          {catLabel}
        </a>
        <span>&middot;</span>
        <span data-locale-date data-date={date.toISOString()}>{formatDate(date)}</span>
        <span>&middot;</span>
        <span data-locale-mins data-mins={mins}>{mins} 分钟阅读</span>
      </div>

      <h1 class="text-[clamp(1.5rem,4vw,2.25rem)] font-bold leading-[1.15] tracking-[-0.03em] mb-4">
        {title}
      </h1>

      <p class="text-[16px] text-[var(--text-2)] leading-relaxed max-w-[42rem]">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-5">
          {tags.map((tag) => (
            <a href={url(`tags/${slugify(tag)}/`)} class="tag-pill">
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- Content + TOC -->
    <div class="flex gap-16">
      <article class="prose flex-1 min-w-0">
        <slot />
      </article>
      <TOC headings={headings} />
    </div>

    <!-- Related -->
    {relatedPosts.length > 0 && (
      <section class="max-w-[720px] mt-16 pt-8 border-t border-[var(--border)]">
        <h3 class="label mb-4" data-i18n="article.related">相关文章</h3>
        <div>
          {relatedPosts.map((post) => {
            const rl = translations.zh.category[post.category as keyof typeof translations.zh.category]?.label;
            return (
              <a href={url(`posts/${post.slug}/`)} class="group flex items-center justify-between py-3 border-b border-[var(--border)] last:border-b-0">
                <div>
                  <span class="text-[11px] text-[var(--text-3)]" data-i18n={`category.${post.category}.label`}>{rl}</span>
                  <h4 class="text-[15px] font-medium tracking-[-0.01em] group-hover:text-[var(--accent)] transition-colors">{post.title}</h4>
                </div>
                <span class="text-[var(--text-3)] text-sm opacity-0 group-hover:opacity-100 transition-opacity">→</span>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
