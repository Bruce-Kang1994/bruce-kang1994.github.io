---
import '../styles/global.css';
import { profile } from '../data/siteData';

interface Props {
  title: string;
  titleEn?: string;
  description?: string;
  descriptionEn?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  titleEn = 'Kang Xin — B2B Product Manager & Indie Builder',
  description = '康鑫的个人官网。B 端产品经理，也持续独立做产品。',
  descriptionEn = 'Personal site of Kang Xin — B2B product manager and indie builder.',
  structuredData,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="康鑫 / Kang Xin" />
    <meta name="robots" content="index,follow" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Preload Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={titleEn || title} />
    <meta property="og:description" content={descriptionEn || description} />
    <meta property="og:site_name" content="Kang Xin" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:locale:alternate" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={titleEn || title} />
    <meta name="twitter:description" content={descriptionEn || description} />

    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
  </head>

  <body>
    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-lg" style="box-shadow: var(--shadow-ring);">
      <div class="container flex items-center justify-between h-14">
        <a href="/" class="text-sm font-semibold tracking-tight" style="color: var(--gray-10);" data-zh="康鑫" data-en="Kang Xin">康鑫</a>
        <div class="flex items-center gap-1">
          <a href="#proof" class="px-3 py-1.5 rounded-md text-[13px] hover:bg-[var(--gray-1)] transition-colors" style="color: var(--gray-6);" data-zh="结果" data-en="Proof">结果</a>
          <a href="#work" class="px-3 py-1.5 rounded-md text-[13px] hover:bg-[var(--gray-1)] transition-colors" style="color: var(--gray-6);" data-zh="作品" data-en="Work">作品</a>
          <a href="#experience" class="px-3 py-1.5 rounded-md text-[13px] hover:bg-[var(--gray-1)] transition-colors" style="color: var(--gray-6);" data-zh="经历" data-en="Experience">经历</a>
          <a href="#contact" class="px-3 py-1.5 rounded-md text-[13px] hover:bg-[var(--gray-1)] transition-colors" style="color: var(--gray-6);" data-zh="联系" data-en="Contact">联系</a>
          <button id="lang-toggle" class="ml-2 px-2.5 py-1 rounded-md text-xs font-medium cursor-pointer transition-colors hover:bg-[var(--gray-1)]" style="color: var(--gray-4); border: 1px solid var(--gray-2);" aria-label="Switch language">EN</button>
        </div>
      </div>
    </nav>

    <main class="pt-14">
      <slot />
    </main>

    <footer style="border-top: 1px solid var(--gray-2);" class="py-8">
      <div class="container flex items-center justify-between">
        <span class="caption" data-zh="© 2026 康鑫" data-en="© 2026 Kang Xin">© 2026 康鑫</span>
        <span class="caption" data-zh="康鑫个人主站" data-en="Kang Xin Personal Hub">康鑫个人主站</span>
      </div>
    </footer>

    <script>
      let lang: 'zh' | 'en' = 'zh';
      const toggle = document.getElementById('lang-toggle');

      function applyLang() {
        document.querySelectorAll<HTMLElement>('[data-zh]').forEach((el) => {
          const text = el.getAttribute(lang === 'zh' ? 'data-zh' : 'data-en');
          if (text) el.textContent = text;
        });
        if (toggle) toggle.textContent = lang === 'zh' ? 'EN' : '中';
        document.documentElement.lang = lang === 'zh' ? 'zh-CN' : 'en';
      }

      toggle?.addEventListener('click', () => {
        lang = lang === 'zh' ? 'en' : 'zh';
        applyLang();
      });

      // Scroll reveal
      const observer = new IntersectionObserver(
        (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('is-visible'); }),
        { threshold: 0.06 }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
