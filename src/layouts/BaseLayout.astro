---
import '../styles/global.css';
import { translations } from '../lib/i18n';
import { contact, profile } from '../data/siteData';

interface Props {
  title: string;
  description?: string;
  section?: 'home' | 'lab' | 'postmem';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Bruce Kang — Product Manager, PostMem Co-Founder.',
  section = 'home',
  structuredData,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const isActive = (path: string) => {
  if (path === '/') return currentPath === '/';
  return currentPath === path || currentPath.startsWith(path);
};

const siteTitle = section === 'lab'
  ? `${title} | Bruce's Growth Lab`
  : section === 'postmem'
    ? `${title} | PostMem`
    : title;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Bruce Kang / 康鑫" />
    <meta name="robots" content="index,follow" />

    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&family=Source+Sans+3:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Bruce Kang" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}

    <script is:inline>
      (function() {
        var locale = localStorage.getItem('locale') || localStorage.getItem('lang') || 'zh';
        if (locale === 'en') {
          document.documentElement.classList.add('lang-en');
          document.documentElement.lang = 'en';
        }
        document.documentElement.dataset.locale = locale;
        localStorage.setItem('locale', locale);
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme:dark)').matches)) document.documentElement.classList.add('dark');
      })();
    </script>
  </head>

  <body class="min-h-screen flex flex-col">

    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-header__brand">Bruce Kang</a>
        <nav class="site-nav" id="site-nav">
          <a href="/" class:list={['site-nav__link', isActive('/') && !isActive('/lab/') && !isActive('/postmem/') && 'is-active']}>
            <span data-lang="zh">首页</span><span data-lang="en">Home</span>
          </a>
          <a href="/lab/" class:list={['site-nav__link', isActive('/lab/') && 'is-active']}>
            Growth Lab
          </a>
          <a href="/postmem/" class:list={['site-nav__link', isActive('/postmem/') && 'is-active']}>
            PostMem SEO
          </a>
          <a href="/#contact" class="site-nav__link">
            <span data-lang="zh">联系</span><span data-lang="en">Contact</span>
          </a>
        </nav>
        <div class="site-header__right">
          <div class="locale-switch" role="group" aria-label="Language">
            <button type="button" class="locale-btn" data-set-locale="zh" aria-pressed="true">中</button>
            <button type="button" class="locale-btn" data-set-locale="en" aria-pressed="false">EN</button>
          </div>
          <button id="theme-toggle" class="ctrl-btn" aria-label="Toggle theme">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/></svg>
          </button>
          <button id="mobile-menu-toggle" class="ctrl-btn mobile-only" aria-label="Menu">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
      </div>

      <nav id="mobile-nav" class="mobile-nav hidden">
        <a href="/" class="mobile-nav__link">
          <span data-lang="zh">首页</span><span data-lang="en">Home</span>
        </a>
        <a href="/lab/" class="mobile-nav__link">Growth Lab</a>
        <a href="/postmem/" class="mobile-nav__link">PostMem SEO</a>
        <a href="/#contact" class="mobile-nav__link">
          <span data-lang="zh">联系</span><span data-lang="en">Contact</span>
        </a>
      </nav>
    </header>

    <main class="flex-1"><slot /></main>

    <footer id="contact" class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__left">
          <p class="site-footer__bio">
            <span data-lang="zh">{profile.bio.zh}</span>
            <span data-lang="en">{profile.bio.en}</span>
          </p>
          <div class="site-footer__links">
            <a href="/lab/about/" class="site-footer__about">
              <span data-lang="zh">关于我 →</span>
              <span data-lang="en">About me →</span>
            </a>
            <a href={`mailto:${contact.email}`} class="site-footer__email">{contact.email}</a>
            <a href={contact.github} target="_blank" rel="noopener" class="site-footer__ext">GitHub ↗</a>
          </div>
        </div>
        <div class="site-footer__right">
          &copy; {new Date().getFullYear()} Bruce Kang
        </div>
      </div>
    </footer>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(250, 249, 247, 0.88);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      :global(.dark) .site-header {
        background: rgba(12, 10, 9, 0.88);
      }
      .site-header__inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 1.5rem;
        height: 3.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .site-header__brand {
        font-size: 14px;
        font-weight: 700;
        color: var(--text-1);
        text-decoration: none;
        letter-spacing: -0.02em;
      }
      .site-nav {
        display: flex;
        align-items: center;
        gap: 0.125rem;
      }
      .site-nav__link {
        padding: 0.3rem 0.6rem;
        font-size: 13px;
        font-weight: 500;
        color: var(--text-3);
        text-decoration: none;
        border-radius: var(--radius-sm);
        transition: color 120ms ease, background 120ms ease;
      }
      .site-nav__link:hover { color: var(--text-1); }
      .site-nav__link.is-active { color: var(--text-1); background: var(--bg-alt); }
      .site-header__right {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }
      .locale-switch {
        display: inline-flex;
        align-items: center;
        gap: 1px;
        padding: 2px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
      }
      .locale-btn {
        min-width: 28px;
        height: 24px;
        padding: 0 6px;
        border-radius: 3px;
        font-size: 11px;
        font-weight: 600;
        color: var(--text-3);
        transition: color 120ms ease, background 120ms ease;
        cursor: pointer;
        border: none;
        background: none;
      }
      .locale-btn.is-active {
        color: var(--text-1);
        background: var(--bg-alt);
      }
      .ctrl-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: var(--radius-sm);
        color: var(--text-3);
        background: none;
        border: none;
        cursor: pointer;
        transition: color 120ms ease, background 120ms ease;
      }
      .ctrl-btn:hover { color: var(--text-1); background: var(--bg-alt); }
      .mobile-only { display: none; }

      .mobile-nav {
        border-top: 1px solid var(--border);
        background: var(--bg);
        padding: 0.5rem 1.5rem 0.75rem;
      }
      .mobile-nav__link {
        display: block;
        padding: 0.5rem 0;
        font-size: 14px;
        font-weight: 500;
        color: var(--text-2);
        text-decoration: none;
      }
      .mobile-nav__link:hover { color: var(--text-1); }

      .site-footer {
        border-top: 1px solid var(--border);
        margin-top: 5rem;
      }
      .site-footer__inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1.5rem;
      }
      .site-footer__bio {
        font-size: 13px;
        color: var(--text-3);
        max-width: 480px;
        margin-bottom: 0.75rem;
        line-height: 1.6;
      }
      .site-footer__links { display: flex; align-items: center; gap: 1rem; }
      .site-footer__about {
        font-size: 13px;
        font-weight: 500;
        color: var(--accent);
        text-decoration: none;
        transition: color 150ms ease;
      }
      .site-footer__about:hover { color: var(--accent-hover); }
      .site-footer__email {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-1);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: var(--border-strong);
      }
      .site-footer__email:hover { text-decoration-color: var(--text-1); }
      .site-footer__ext {
        font-size: 12px;
        color: var(--text-3);
        text-decoration: none;
      }
      .site-footer__ext:hover { color: var(--text-2); }
      .site-footer__right {
        font-size: 12px;
        color: var(--text-3);
      }

      @media (max-width: 768px) {
        .site-nav { display: none; }
        .mobile-only { display: flex; }
        .site-footer__inner { flex-direction: column; align-items: flex-start; }
      }
    </style>

    <script is:inline define:vars={{ i18nMessages: translations }}>
      var getNestedValue = function(obj, key) { return key.split('.').reduce(function(acc, part) { return acc && acc[part]; }, obj); };
      var formatLocaleDate = function(value, locale) {
        var date = new Date(value);
        if (isNaN(date.valueOf())) return value;
        return locale === 'en'
          ? date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
          : date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
      };
      var applyLocale = function(locale) {
        document.documentElement.lang = locale === 'en' ? 'en' : 'zh-CN';
        document.documentElement.dataset.locale = locale;
        localStorage.setItem('locale', locale);
        localStorage.setItem('lang', locale);
        if (locale === 'en') {
          document.documentElement.classList.add('lang-en');
        } else {
          document.documentElement.classList.remove('lang-en');
        }
        document.querySelectorAll('[data-i18n]').forEach(function(node) {
          var key = node.getAttribute('data-i18n');
          var value = getNestedValue(i18nMessages[locale], key);
          if (value) node.textContent = value;
        });
        document.querySelectorAll('[data-copy-zh][data-copy-en]').forEach(function(node) {
          node.textContent = locale === 'en' ? node.getAttribute('data-copy-en') : node.getAttribute('data-copy-zh');
        });
        document.querySelectorAll('[data-locale-date]').forEach(function(node) {
          var rawDate = node.getAttribute('data-date');
          if (rawDate) node.textContent = formatLocaleDate(rawDate, locale);
        });
        document.querySelectorAll('[data-locale-mins]').forEach(function(node) {
          var mins = Number(node.getAttribute('data-mins') || '0');
          node.textContent = locale === 'en' ? mins + ' min read' : mins + ' 分钟阅读';
        });
        document.querySelectorAll('[data-locale-count]').forEach(function(node) {
          var count = Number(node.getAttribute('data-count') || '0');
          node.textContent = locale === 'en' ? count + ' posts' : count + ' 篇内容';
        });
        document.querySelectorAll('[data-locale-tag-count]').forEach(function(node) {
          var count = Number(node.getAttribute('data-count') || '0');
          node.textContent = locale === 'en' ? count + ' tags' : count + ' 个标签';
        });
        document.querySelectorAll('[data-set-locale]').forEach(function(button) {
          var isActiveLocale = button.getAttribute('data-set-locale') === locale;
          button.classList.toggle('is-active', isActiveLocale);
          button.setAttribute('aria-pressed', isActiveLocale ? 'true' : 'false');
        });
      };

      var initialLocale = localStorage.getItem('locale') || localStorage.getItem('lang') || 'zh';
      if (initialLocale !== 'en') initialLocale = 'zh';
      applyLocale(initialLocale);

      var themeToggle = document.getElementById('theme-toggle');
      if (themeToggle) {
        themeToggle.addEventListener('click', function() {
          document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
        });
      }

      document.querySelectorAll('[data-set-locale]').forEach(function(button) {
        button.addEventListener('click', function() {
          var locale = button.getAttribute('data-set-locale');
          if (locale === 'zh' || locale === 'en') applyLocale(locale);
        });
      });

      var menuToggle = document.getElementById('mobile-menu-toggle');
      var mobileNav = document.getElementById('mobile-nav');
      if (menuToggle && mobileNav) {
        menuToggle.addEventListener('click', function() {
          mobileNav.classList.toggle('hidden');
        });
      }

      var revealObs = new IntersectionObserver(
        function(entries) { entries.forEach(function(e) { if (e.isIntersecting) e.target.classList.add('is-visible'); }); },
        { threshold: 0.06 }
      );
      document.querySelectorAll('[data-reveal]').forEach(function(el) { revealObs.observe(el); });
    </script>
  </body>
</html>
