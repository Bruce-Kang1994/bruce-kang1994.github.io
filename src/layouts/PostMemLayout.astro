---
import BaseLayout from './BaseLayout.astro';
import '../styles/postmem.css';

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  datePublished?: Date;
  dateModified?: Date;
}

const { title, description, keywords = [], datePublished, dateModified } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  url: canonicalURL.toString(),
  author: { '@type': 'Organization', name: 'PostMem' },
  publisher: { '@type': 'Organization', name: 'PostMem', url: 'https://www.postmem.com' },
  ...(datePublished && { datePublished: datePublished.toISOString().split('T')[0] }),
  ...(dateModified && { dateModified: dateModified.toISOString().split('T')[0] }),
  ...(keywords.length > 0 && { keywords: keywords.join(', ') }),
};
---

<BaseLayout title={title} description={description} section="postmem" structuredData={articleSchema}>
  <div class="max-w-[740px] mx-auto px-5">
    <header class="pt-12 pb-6">
      <a href="/postmem/" class="inline-block text-[13px] font-medium text-[var(--accent)] no-underline mb-5 hover:underline hover:underline-offset-[3px]">
        &larr; <span data-lang="zh">返回文章列表</span><span data-lang="en">PostMem SEO</span>
      </a>
      {keywords.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-3">
          {keywords.slice(0, 3).map((k) => (
            <span class="pm-badge">{k}</span>
          ))}
        </div>
      )}
      <h1 class="text-[clamp(1.5rem,4vw,2.25rem)] font-bold leading-[1.2] tracking-[-0.02em] mb-3">
        {title}
      </h1>
      <p class="text-[16px] text-[var(--text-2)] leading-[1.7] max-w-[600px]">
        {description}
      </p>
      {datePublished && (
        <div class="mt-3 text-[13px] text-[var(--text-3)]">
          <time datetime={datePublished.toISOString().split('T')[0]}
            data-locale-date data-date={datePublished.toISOString()}>
            {datePublished.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {dateModified && (
            <span>
              · <span data-lang="zh">更新于</span><span data-lang="en">Updated</span>{' '}
              <time data-locale-date data-date={dateModified.toISOString()}>
                {dateModified.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </span>
          )}
        </div>
      )}
    </header>

    <article class="prose">
      <slot />
    </article>

    <footer class="py-8 mt-8 border-t border-[var(--border)]">
      <a href="/postmem/" class="inline-block text-[13px] font-medium text-[var(--accent)] no-underline hover:underline hover:underline-offset-[3px]">
        &larr; <span data-lang="zh">返回文章列表</span><span data-lang="en">Back to all articles</span>
      </a>
    </footer>
  </div>
</BaseLayout>
