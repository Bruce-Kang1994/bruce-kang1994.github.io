---
import ArticleCard from './ArticleCard.astro';

interface Props {
  id?: string;
  eyebrow: string;
  titleZh: string;
  titleEn: string;
  descZh: string;
  descEn: string;
  posts: {
    id: string;
    data: {
      title: string;
      description: string;
      category: string;
      tags: string[];
      date: Date;
    };
    body?: string;
  }[];
  href: string;
  linkLabelZh: string;
  linkLabelEn: string;
}

const { id, eyebrow, titleZh, titleEn, descZh, descEn, posts, href, linkLabelZh, linkLabelEn } = Astro.props;
---

<section id={id} class="topic-cluster" data-reveal>
  <div class="topic-cluster__label">{eyebrow}</div>
  <h2 class="topic-cluster__title">
    <span data-lang="zh">{titleZh}</span>
    <span data-lang="en">{titleEn}</span>
  </h2>
  <p class="topic-cluster__desc">
    <span data-lang="zh">{descZh}</span>
    <span data-lang="en">{descEn}</span>
  </p>
  <div class="topic-cluster__list">
    {posts.map((post) => (
      <ArticleCard
        title={post.data.title}
        description={post.data.description}
        category={post.data.category}
        tags={post.data.tags}
        date={post.data.date}
        slug={post.id}
        body={post.body || ''}
      />
    ))}
  </div>
  <a href={href} class="topic-cluster__link">
    <span data-lang="zh">{linkLabelZh}</span>
    <span data-lang="en">{linkLabelEn}</span>
  </a>
</section>

<style>
  .topic-cluster {
    padding: clamp(1.75rem, 4vw, 2.5rem) 0;
    border-top: 1px solid var(--border);
    scroll-margin-top: 4rem;
  }
  .topic-cluster:first-child {
    border-top: none;
  }
  .topic-cluster__label {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
    margin-bottom: 0.5rem;
  }
  .topic-cluster__title {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--text-1);
    margin-bottom: 0.375rem;
  }
  .topic-cluster__desc {
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.6;
    max-width: 540px;
    margin-bottom: 1.5rem;
  }
  .topic-cluster__list {
    display: flex;
    flex-direction: column;
  }
  .topic-cluster__link {
    display: inline-flex;
    align-items: center;
    margin-top: 1rem;
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .topic-cluster__link::after {
    content: ' →';
    margin-left: 0.25rem;
    transition: transform 150ms ease;
  }
  .topic-cluster__link:hover {
    color: var(--accent-hover);
  }
  .topic-cluster__link:hover::after {
    transform: translateX(3px);
  }
</style>
