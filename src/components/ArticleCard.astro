---
import { categoryColors, formatDate, readingTime, withBase } from '../lib/utils';
import { translations } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  date: Date;
  slug: string;
  body?: string;
}

const { title, description, category, tags, date, slug, body = '' } = Astro.props;
const url = (path: string) => withBase(path, '/lab');
const catLabel = translations.zh.category[category as keyof typeof translations.zh.category]?.label || category;
const catLabelEn = translations.en.category[category as keyof typeof translations.en.category]?.label || category;
const mins = readingTime(body);
const tone = categoryColors[category] ?? categoryColors.frameworks;
---

<a href={url(`posts/${slug}/`)} class="post-link group block py-5">
  <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mb-1.5 text-[12px] text-[var(--text-3)]">
    <span class:list={['inline-flex items-center gap-1 rounded border px-2 py-0.5 text-[11px] font-semibold', tone.bg, tone.text, tone.border]} data-copy-zh={catLabel} data-copy-en={catLabelEn}>
      {catLabel}
    </span>
    <span>&middot;</span>
    <span data-locale-date data-date={date.toISOString()}>{formatDate(date)}</span>
    <span>&middot;</span>
    <span data-locale-mins data-mins={mins}>{mins} 分钟阅读</span>
  </div>

  <h3 class="text-[17px] font-semibold leading-snug tracking-[-0.01em] text-[var(--text-1)] group-hover:text-[var(--accent)] transition-colors duration-150 mb-1">
    {title}
  </h3>
  <p class="text-[14px] text-[var(--text-2)] leading-relaxed max-w-[44rem]">
    {description}
  </p>
</a>

<style>
  .post-link {
    border-bottom: 1px solid var(--border);
  }
  .post-link:last-child {
    border-bottom: none;
  }
</style>
