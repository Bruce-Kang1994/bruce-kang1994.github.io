---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{toc.length > 0 && (
  <aside class="toc-aside">
    <h4 class="label mb-3" data-i18n="article.toc">目录</h4>
    <ul class="toc-list">
      {toc.map((h) => (
        <li>
          <a
            href={`#${h.slug}`}
            class:list={[
              "toc-link",
              h.depth === 3 && "toc-link--nested",
            ]}
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}

<style>
  .toc-aside {
    display: none;
    position: sticky;
    top: 5rem;
    width: 14rem;
    flex-shrink: 0;
    align-self: flex-start;
  }
  @media (min-width: 1280px) {
    .toc-aside { display: block; }
  }
  .toc-list {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    border-left: 1px solid var(--border);
    font-size: 13px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-link {
    display: block;
    padding: 0.25rem 0 0.25rem 1rem;
    color: var(--text-3);
    text-decoration: none;
    border-left: 1px solid transparent;
    margin-left: -1px;
    transition: color 120ms ease, border-color 120ms ease;
  }
  .toc-link:hover {
    color: var(--text-1);
    border-left-color: var(--accent);
  }
  .toc-link--nested {
    padding-left: 2rem;
    font-size: 12px;
  }
</style>
