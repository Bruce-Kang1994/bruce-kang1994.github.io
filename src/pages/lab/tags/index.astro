---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/lab.css';
import { getCollection } from 'astro:content';
import { slugify } from '../../../lib/utils';

const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
const tagCounts = new Map<string, number>();
allPosts.forEach((p) => p.data.tags.forEach((t) => tagCounts.set(t, (tagCounts.get(t) || 0) + 1)));
const sorted = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="标签" section="lab">
  <div class="max-w-[960px] mx-auto px-6">
    <section class="pt-12 sm:pt-16 pb-6">
      <div class="label mb-4">Topic Map · {sorted.length}</div>
      <h1 class="text-[clamp(1.75rem,4vw,2.5rem)] font-bold tracking-[-0.03em] leading-tight mb-3" data-copy-zh="按标签浏览整站内容" data-copy-en="Browse by tag">按标签浏览整站内容</h1>
      <p class="text-[15px] text-[var(--text-2)] leading-relaxed max-w-[540px]" data-copy-zh="标签是横向索引。从一个问题域切入，快速串起相关框架、案例和笔记。" data-copy-en="Tags work as a cross-index. Pick a topic to see related frameworks, cases, and notes.">
        标签是横向索引。从一个问题域切入，快速串起相关框架、案例和笔记。
      </p>
    </section>
    <div class="border-t border-[var(--border)]"></div>
    <section class="py-8 pb-20">
      <div class="flex flex-wrap gap-2">
        {sorted.map(([tag, count]) => (
          <a href={`/lab/tags/${slugify(tag)}/`} class="tag-pill">
            {tag} <span class="text-[var(--text-3)] ml-1">{count}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
