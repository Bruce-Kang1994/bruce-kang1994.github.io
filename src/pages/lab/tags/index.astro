---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/lab.css';
import { getCollection } from 'astro:content';
import { slugify } from '../../../lib/utils';

const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
const tagCounts = new Map<string, number>();
allPosts.forEach((p) => p.data.tags.forEach((t) => tagCounts.set(t, (tagCounts.get(t) || 0) + 1)));
const sorted = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="标签" section="lab">
  <div class="max-w-[1160px] mx-auto px-6">
    <section class="py-14 sm:py-20">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-end">
        <div>
          <div class="eyebrow mb-5">Topic Map</div>
          <h1 class="display-serif text-[38px] sm:text-[52px] leading-[1.04] tracking-[-0.04em] mb-5">按标签浏览整站内容。</h1>
          <p class="max-w-[42rem] text-[16px] sm:text-[17px] leading-relaxed text-[rgb(var(--text-2))]">
            标签更像一张横向索引图。你可以从一个问题域切入，快速把相关框架、案例和笔记串起来看。
          </p>
        </div>
        <aside class="paper-card p-5 sm:p-6">
          <div class="section-kicker mb-3">{sorted.length} 个标签</div>
          <p class="text-[14px] leading-relaxed text-[rgb(var(--text-2))]">
            当前站内共有 {allPosts.length} 篇文章。
          </p>
        </aside>
      </div>
    </section>
    <div class="rule"></div>
    <section class="py-10 pb-20">
      <div class="paper-card p-6">
        <div class="flex flex-wrap gap-2.5">
          {sorted.map(([tag, count]) => (
            <a href={`/lab/tags/${slugify(tag)}/`} class="tag-pill">
              {tag} <span class="text-[rgb(var(--text-3))] ml-1">{count}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
