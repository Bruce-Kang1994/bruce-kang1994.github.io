---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/lab.css';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../../../lib/utils';

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
  const tagSet = new Set<string>();
  allPosts.forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)));
  return [...tagSet].map((tag) => ({
    params: { tag: slugify(tag) },
    props: {
      tag,
      posts: allPosts.filter((p) => p.data.tags.includes(tag)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag}`} section="lab">
  <div class="max-w-[960px] mx-auto px-6">
    <section class="pt-12 sm:pt-16 pb-6">
      <div class="label mb-4">Tag Archive · {posts.length}</div>
      <h1 class="text-[clamp(1.75rem,4vw,2.5rem)] font-bold tracking-[-0.03em] leading-tight mb-3">
        <span class="text-[var(--accent)]">#</span>{tag}
      </h1>
    </section>
    <div class="border-t border-[var(--border)]"></div>
    <section class="py-8 pb-20">
      <div class="article-list">
        {posts.map((post: any) => (
          <ArticleCard title={post.data.title} description={post.data.description} category={post.data.category}
            tags={post.data.tags} date={post.data.date} slug={post.id} body={post.body || ''} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
