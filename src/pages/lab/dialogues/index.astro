---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/lab.css';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { categoryArchiveMeta } from '../../../lib/archive';

const posts = (await getCollection('posts'))
  .filter((p) => p.data.category === 'dialogues' && !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const meta = categoryArchiveMeta.dialogues;
---

<BaseLayout title={meta.title} description={meta.intro} section="lab">
  <div class="max-w-[1160px] mx-auto px-6">
    <section class="py-14 sm:py-20">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-end">
        <div>
          <div class="eyebrow mb-5">{meta.eyebrow}</div>
          <h1 class="display-serif text-[38px] sm:text-[52px] leading-[1.04] tracking-[-0.04em] mb-5">{meta.title}</h1>
          <p class="max-w-[42rem] text-[16px] sm:text-[17px] leading-relaxed text-[rgb(var(--text-2))]">{meta.intro}</p>
        </div>
        <aside class="paper-card p-5 sm:p-6">
          <div class="section-kicker mb-3">{posts.length} 篇文章</div>
          <p class="text-[14px] leading-relaxed text-[rgb(var(--text-2))]">{meta.note}</p>
        </aside>
      </div>
    </section>
    <div class="rule"></div>
    <section class="py-10 pb-20">
      {posts.length > 0 ? (
        <div class="paper-card px-6">
          {posts.map((post) => (
            <ArticleCard title={post.data.title} description={post.data.description} category={post.data.category}
              tags={post.data.tags} date={post.data.date} slug={post.id} body={post.body || ''} />
          ))}
        </div>
      ) : (
        <div class="muted-panel p-6">
          <p class="text-[15px] leading-relaxed text-[rgb(var(--text-2))]">{meta.empty}</p>
        </div>
      )}
    </section>
  </div>
</BaseLayout>
