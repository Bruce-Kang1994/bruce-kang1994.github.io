---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/lab.css';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { categoryColors, formatDate, readingTime } from '../../lib/utils';
import { translations } from '../../lib/i18n';

const allPosts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPosts = allPosts.filter((p) => p.data.featured);
const leadPost = featuredPosts[0] ?? allPosts[0];
const latestPosts = allPosts.filter((p) => p.id !== leadPost?.id).slice(0, 5);
const highlightedPosts = allPosts.filter((p) => p.id !== leadPost?.id).slice(0, 3);
const url = (path: string) => `/lab/${path}`;
const zh = translations.zh;
const en = translations.en;
const cats = zh.category;
const totalTags = new Set(allPosts.flatMap((post) => post.data.tags)).size;
const categoryEntries = Object.entries(cats).map(([key, val]) => ({
  key,
  labelZh: val.label,
  descZh: val.desc,
  labelEn: en.category[key as keyof typeof en.category]?.label ?? val.label,
  descEn: en.category[key as keyof typeof en.category]?.desc ?? val.desc,
  count: allPosts.filter((post) => post.data.category === key).length,
  tone: categoryColors[key] ?? categoryColors.frameworks,
}));
const readingPaths = [
  {
    titleZh: '先看通用框架',
    titleEn: 'Start with the core framework',
    descZh: '如果你想先建立一套判断产品增长问题的基本骨架，从 8 维度分析开始。',
    descEn: 'Build a reusable mental model first, then use the cases to understand how it gets applied.',
    href: url('posts/growth-dimension-framework/'),
  },
  {
    titleZh: '再看真实案例',
    titleEn: 'Then read real teardowns',
    descZh: '把抽象方法放回真实业务里，检查它在美团、ElevenLabs 这类产品上如何成立。',
    descEn: 'Move from abstract frameworks to real products and see how the structure holds up in practice.',
    href: url('case-studies/'),
  },
  {
    titleZh: '最后看工作笔记',
    titleEn: 'Finish with working notes',
    descZh: '那些还在形成中的观点、对话和研究线索，会先出现在 notes 和 dialogues。',
    descEn: 'The rough edges, in-progress ideas, and research fragments show up here before they become essays.',
    href: url('notes/'),
  },
];
const leadReadMinutes = leadPost ? readingTime(leadPost.body || '') : 0;
---

<BaseLayout title="首页" section="lab">
  <div class="max-w-[1160px] mx-auto px-6">
    <section class="pt-8 sm:pt-10 pb-10 sm:pb-12">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-end">
        <div>
          <div class="eyebrow mb-4" data-copy-zh="Bruce Kang 的增长研究" data-copy-en="Bruce Kang's Growth Research">Bruce Kang 的增长研究</div>
          <h1 class="display-serif text-[28px] sm:text-[40px] leading-[1.1] tracking-[-0.04em] max-w-[20ch]" data-copy-zh="把增长拆成结构，再把结构变成执行。" data-copy-en="Break growth into structure, then turn structure into execution.">
            把增长拆成结构，再把结构变成执行。
          </h1>
          <p class="mt-5 max-w-[44rem] text-[17px] sm:text-[19px] leading-relaxed text-[rgb(var(--text-2))]" data-copy-zh="我把增长当成一套可设计、可迁移的工作系统来写。这里有方法框架、真实拆解，也有正在形成中的研究线索，但不会做成信息流。" data-copy-en="I write about growth as a system that can be designed, transferred, and executed. You will find frameworks, real teardowns, and research threads here, but not a content feed.">
            我把增长当成一套可设计、可迁移的工作系统来写。这里有方法框架、真实拆解，也有正在形成中的研究线索，但不会做成信息流。
          </p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a href={url('frameworks/')} class="tag-pill" data-copy-zh="从框架开始" data-copy-en="Start with frameworks">从框架开始</a>
            <a href={url('case-studies/')} class="tag-pill" data-copy-zh="看真实拆解" data-copy-en="See real teardowns">看真实拆解</a>
            <a href={url('about/')} class="tag-pill" data-copy-zh="了解这个站怎么写" data-copy-en="How this site is written">了解这个站怎么写</a>
          </div>

          <div class="mt-6 flex flex-wrap gap-3">
            <div class="metric-chip">
              <span class="metric-chip__value">{allPosts.length}</span>
              <span class="metric-chip__label" data-copy-zh="篇公开文章" data-copy-en="published essays">篇公开文章</span>
            </div>
            <div class="metric-chip">
              <span class="metric-chip__value">{totalTags}</span>
              <span class="metric-chip__label" data-copy-zh="个主题标签" data-copy-en="topic tags">个主题标签</span>
            </div>
            <div class="metric-chip">
              <span class="metric-chip__value">1</span>
              <span class="metric-chip__label" data-copy-zh="个长期研究站" data-copy-en="living research archive">个长期研究站</span>
            </div>
          </div>
        </div>

        <aside class="paper-card p-5 sm:p-6 self-start">
          <div class="section-kicker mb-4" data-copy-zh="建议阅读顺序" data-copy-en="Recommended Reading Order">建议阅读顺序</div>
          <div class="reading-order-list">
            {readingPaths.map((path, i) => (
              <a href={path.href} class:list={['reading-order-item group', i === 0 && 'is-primary']}>
                <span class="reading-order-item__index">{i + 1}</span>
                <div class="reading-order-item__body">
                  <div class="reading-order-item__title" data-copy-zh={path.titleZh} data-copy-en={path.titleEn}>{path.titleZh}</div>
                  <div class="reading-order-item__desc" data-copy-zh={path.descZh} data-copy-en={path.descEn}>{path.descZh}</div>
                </div>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <div class="rule"></div>

    <section class="py-10">
      <div class="flex items-end justify-between gap-4 mb-6">
        <div>
          <div class="section-kicker mb-2" data-copy-zh="研究方向" data-copy-en="Research Tracks">研究方向</div>
          <h2 class="display-serif text-[28px] sm:text-[34px] tracking-[-0.03em]" data-copy-zh="这个站目前在研究什么" data-copy-en="What this site is actively working on">这个站目前在研究什么</h2>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {categoryEntries.map((entry) => (
          <a href={url(`${entry.key}/`)} class="track-card p-5 group">
            <div class="flex items-center justify-between gap-4 mb-6">
              <span class:list={['track-card__icon', entry.tone.bg, entry.tone.text, entry.tone.border]}>{entry.tone.icon}</span>
              <span class="text-[11px] uppercase tracking-[0.12em] text-[rgb(var(--text-3))]" data-locale-count data-count={entry.count}></span>
            </div>
            <h3 class="text-[18px] font-semibold tracking-[-0.02em] mb-2 group-hover:text-[rgb(var(--accent))] transition-colors" data-copy-zh={entry.labelZh} data-copy-en={entry.labelEn}>
              {entry.labelZh}
            </h3>
            <p class="text-[14px] leading-relaxed text-[rgb(var(--text-2))]" data-copy-zh={entry.descZh} data-copy-en={entry.descEn}>{entry.descZh}</p>
          </a>
        ))}
      </div>
    </section>

    {leadPost && (
      <>
        <div class="rule"></div>

        <section class="py-10">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.85fr)] lg:items-start">
            <article class="paper-card paper-card--accent lead-essay-card p-6 sm:p-8">
              <div class="section-kicker mb-5" data-copy-zh="代表文章" data-copy-en="Lead Essay">代表文章</div>
              <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[13px] text-[rgb(var(--text-3))] mb-4">
                <span class:list={['inline-flex items-center rounded-full border px-2.5 py-1 text-[12px] font-semibold', categoryColors[leadPost.data.category]?.bg, categoryColors[leadPost.data.category]?.text, categoryColors[leadPost.data.category]?.border]}>
                  <span data-copy-zh={cats[leadPost.data.category as keyof typeof cats]?.label} data-copy-en={en.category[leadPost.data.category as keyof typeof en.category]?.label ?? cats[leadPost.data.category as keyof typeof cats]?.label}>
                    {cats[leadPost.data.category as keyof typeof cats]?.label}
                  </span>
                </span>
                <span>&middot;</span>
                <span data-locale-date data-date={leadPost.data.date.toISOString()}>{formatDate(leadPost.data.date)}</span>
              </div>
              <a href={url(`posts/${leadPost.id}/`)} class="editorial-link block">
                <h2 class="display-serif text-[28px] sm:text-[36px] leading-[1.04] tracking-[-0.045em] max-w-[14ch]">
                  {leadPost.data.title}
                </h2>
              </a>
              <p class="mt-5 max-w-[42rem] text-[16px] leading-relaxed text-[rgb(var(--text-2))]">
                {leadPost.data.description}
              </p>

              <div class="lead-essay__meta-grid mt-7">
                <div class="lead-essay__meta-tile">
                  <div class="lead-essay__meta-label" data-copy-zh="发布时间" data-copy-en="Published">发布时间</div>
                  <div class="lead-essay__meta-value" data-locale-date data-date={leadPost.data.date.toISOString()}>{formatDate(leadPost.data.date)}</div>
                </div>
                <div class="lead-essay__meta-tile">
                  <div class="lead-essay__meta-label" data-copy-zh="阅读时长" data-copy-en="Read time">阅读时长</div>
                  <div class="lead-essay__meta-value" data-locale-mins data-mins={leadReadMinutes}>{leadReadMinutes} 分钟</div>
                </div>
                <div class="lead-essay__meta-tile">
                  <div class="lead-essay__meta-label" data-copy-zh="包含标签" data-copy-en="Tagged with">包含标签</div>
                  <div class="lead-essay__meta-value" data-locale-tag-count data-count={leadPost.data.tags.length}>
                    {leadPost.data.tags.length} 个标签
                  </div>
                </div>
              </div>

              <div class="lead-essay__footer mt-7">
                <div class="flex flex-wrap gap-2">
                  {leadPost.data.tags.slice(0, 3).map((tag) => (
                    <span class="tag-pill">{tag}</span>
                  ))}
                </div>
                <a href={url(`posts/${leadPost.id}/`)} class="lead-essay__cta">
                  <span data-copy-zh="读这篇文章" data-copy-en="Read this essay">读这篇文章</span>
                  <span aria-hidden="true">↗</span>
                </a>
              </div>
            </article>

            <aside class="flex flex-col gap-4">
              <div class="muted-panel muted-panel--brand p-5">
                <div class="section-kicker mb-3" data-copy-zh="建议读法" data-copy-en="How To Read">建议读法</div>
                <p class="text-[14px] leading-relaxed text-[rgb(var(--text-2))]" data-copy-zh="如果你是第一次来，先看这篇总框架，再回到案例拆解，会更容易看出每个增长动作背后的结构。" data-copy-en="If this is your first visit, start with the framework essay and then move into the case studies. The structure will become easier to see.">
                  如果你是第一次来，先看这篇总框架，再回到案例拆解，会更容易看出每个增长动作背后的结构。
                </p>
              </div>
              <div class="paper-card p-5">
                <div class="section-kicker mb-4" data-copy-zh="也可以从这里开始" data-copy-en="Also Start Here">也可以从这里开始</div>
                <div class="space-y-1">
                  {highlightedPosts.map((post) => (
                    <ArticleCard
                      title={post.data.title}
                      description={post.data.description}
                      category={post.data.category}
                      tags={post.data.tags}
                      date={post.data.date}
                      slug={post.id}
                      body={post.body || ''}
                    />
                  ))}
                </div>
              </div>
            </aside>
          </div>
        </section>
      </>
    )}

    <div class="rule"></div>

    <section class="py-10">
      <div class="flex items-end justify-between gap-4 mb-6">
        <div>
          <div class="section-kicker mb-2" data-copy-zh="阅读路径" data-copy-en="Reading Paths">阅读路径</div>
          <h2 class="display-serif text-[28px] sm:text-[34px] tracking-[-0.03em]" data-copy-zh="不同读法，从不同入口开始" data-copy-en="Different ways in, depending on how you like to read">不同读法，从不同入口开始</h2>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {readingPaths.map((item) => (
          <a href={item.href} class="path-card p-5 group">
            <div class="text-[11px] uppercase tracking-[0.12em] text-[rgb(var(--text-3))] mb-4" data-copy-zh="从这里开始" data-copy-en="Start Here">从这里开始</div>
            <h3 class="text-[19px] font-semibold tracking-[-0.02em] mb-2 group-hover:text-[rgb(var(--accent))] transition-colors">
              <span data-copy-zh={item.titleZh} data-copy-en={item.titleEn}>{item.titleZh}</span>
            </h3>
            <p class="text-[14px] leading-relaxed text-[rgb(var(--text-2))]" data-copy-zh={item.descZh} data-copy-en={item.descEn}>{item.descZh}</p>
          </a>
        ))}
      </div>
    </section>

    <div class="rule"></div>

    <section class="py-10 pb-20">
      <div class="flex items-end justify-between gap-4 mb-6">
        <div>
          <div class="section-kicker mb-2" data-copy-zh="最近更新" data-copy-en="Latest Writing">最近更新</div>
          <h2 class="display-serif text-[28px] sm:text-[34px] tracking-[-0.03em]" data-copy-zh="最近写的内容" data-copy-en="Latest writing and notes">最近写的内容</h2>
        </div>
      </div>
      <div class="paper-card px-6">
        {latestPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            tags={post.data.tags}
            date={post.data.date}
            slug={post.id}
            body={post.body || ''}
          />
        ))}
      </div>
    </section>
  </div>
  <!-- ══════════ GSAP Scroll Animations ══════════ -->
  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReduced) {
      // ── Hero entrance ──
      const heroTl = gsap.timeline({ delay: 0.1 });

      heroTl.fromTo('.eyebrow',
        { autoAlpha: 0, x: -30, filter: 'blur(6px)' },
        { autoAlpha: 1, x: 0, filter: 'blur(0px)', duration: 0.5, ease: 'power3.out' }
      );

      heroTl.fromTo('.display-serif',
        { autoAlpha: 0, y: 30, filter: 'blur(4px)' },
        { autoAlpha: 1, y: 0, filter: 'blur(0px)', duration: 0.7, ease: 'power3.out' },
        '-=0.25'
      );

      // Tag pills stagger pop
      heroTl.fromTo('.tag-pill',
        { autoAlpha: 0, scale: 0.7, y: 10 },
        { autoAlpha: 1, scale: 1, y: 0, duration: 0.4, stagger: 0.08, ease: 'back.out(2)' },
        '-=0.3'
      );

      // Metric chips count up
      heroTl.fromTo('.metric-chip',
        { autoAlpha: 0, y: 15 },
        { autoAlpha: 1, y: 0, duration: 0.4, stagger: 0.1, ease: 'power2.out' },
        '-=0.2'
      );

      // Metric number count-up
      document.querySelectorAll('.metric-chip__value').forEach(el => {
        const final = parseInt(el.textContent || '0', 10);
        if (isNaN(final)) return;
        const counter = { val: 0 };
        gsap.to(counter, {
          val: final, duration: 1.2, delay: 0.6, ease: 'power2.out',
          onUpdate: () => { el.textContent = Math.round(counter.val).toString(); }
        });
      });

      // ── Reading order sidebar: items slide in with stagger ──
      const readingItems = document.querySelectorAll('.reading-order-item');
      if (readingItems.length) {
        gsap.fromTo(readingItems,
          { autoAlpha: 0, x: 40 },
          {
            autoAlpha: 1, x: 0,
            duration: 0.5, stagger: 0.15, ease: 'power3.out',
            scrollTrigger: { trigger: '.reading-order-list', start: 'top 85%', once: true }
          }
        );
      }

      // ── Research track cards: stagger from bottom with rotation ──
      const trackCards = document.querySelectorAll('.track-card');
      trackCards.forEach((card, i) => {
        gsap.fromTo(card,
          { autoAlpha: 0, y: 50, rotateX: -5 },
          {
            autoAlpha: 1, y: 0, rotateX: 0,
            duration: 0.6, ease: 'power3.out',
            delay: i * 0.1,
            scrollTrigger: { trigger: card, start: 'top 88%', once: true }
          }
        );
      });

      // ── Lead essay card: scale up from center ──
      gsap.fromTo('.lead-essay-card',
        { autoAlpha: 0, scale: 0.92, y: 40 },
        {
          autoAlpha: 1, scale: 1, y: 0,
          duration: 0.8, ease: 'power3.out',
          scrollTrigger: { trigger: '.lead-essay-card', start: 'top 85%', once: true }
        }
      );

      // ── Reading path cards: slide up with stagger ──
      const pathCards = document.querySelectorAll('.path-card');
      pathCards.forEach((card, i) => {
        gsap.fromTo(card,
          { autoAlpha: 0, y: 40 },
          {
            autoAlpha: 1, y: 0,
            duration: 0.5, ease: 'back.out(1.4)',
            delay: i * 0.12,
            scrollTrigger: { trigger: card, start: 'top 88%', once: true }
          }
        );
      });

      // ── Section kickers: slide from left ──
      document.querySelectorAll('.section-kicker').forEach(el => {
        gsap.fromTo(el,
          { autoAlpha: 0, x: -30 },
          {
            autoAlpha: 1, x: 0,
            duration: 0.5, ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 90%', once: true }
          }
        );
      });

      // ── Section display titles: blur reveal ──
      document.querySelectorAll('section .display-serif').forEach((el, i) => {
        if (i === 0) return; // skip hero (already animated)
        gsap.fromTo(el,
          { autoAlpha: 0, y: 20, filter: 'blur(4px)' },
          {
            autoAlpha: 1, y: 0, filter: 'blur(0px)',
            duration: 0.6, ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 88%', once: true }
          }
        );
      });

      // ── Divider rules: expand from center ──
      document.querySelectorAll('.rule').forEach(rule => {
        gsap.fromTo(rule,
          { scaleX: 0 },
          {
            scaleX: 1,
            duration: 0.6, ease: 'power2.inOut',
            scrollTrigger: { trigger: rule, start: 'top 92%', once: true }
          }
        );
      });

      // ── Latest writing paper card: fade up ──
      const latestCard = document.querySelector('section:last-of-type .paper-card');
      if (latestCard) {
        gsap.fromTo(latestCard,
          { autoAlpha: 0, y: 30 },
          {
            autoAlpha: 1, y: 0,
            duration: 0.6, ease: 'power2.out',
            scrollTrigger: { trigger: latestCard, start: 'top 85%', once: true }
          }
        );
      }
    }
  </script>

</BaseLayout>
