---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/lab.css';
import TopicCluster from '../../components/TopicCluster.astro';
import KnowledgeGraph from '../../components/KnowledgeGraph.astro';
import { getCollection } from 'astro:content';
import { translations } from '../../lib/i18n';
import { categoryArchiveMeta } from '../../lib/archive';

const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
const totalTags = new Set(allPosts.flatMap((post) => post.data.tags)).size;

const zh = translations.zh;
const en = translations.en;

// ── Group & sort by category ──
const frameworks = allPosts
  .filter((p) => p.data.category === 'frameworks')
  .sort((a, b) => (a.data.sortOrder ?? 99) - (b.data.sortOrder ?? 99));

const caseStudies = allPosts
  .filter((p) => p.data.category === 'case-studies')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dialogues = allPosts
  .filter((p) => p.data.category === 'dialogues')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const notes = allPosts
  .filter((p) => p.data.category === 'notes')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const journal = allPosts
  .filter((p) => p.data.category === 'journal')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const clusters = [
  { key: 'frameworks' as const, posts: frameworks, href: '/lab/frameworks/' },
  { key: 'case-studies' as const, posts: caseStudies, href: '/lab/case-studies/' },
  { key: 'dialogues' as const, posts: dialogues, href: '/lab/dialogues/' },
  { key: 'notes' as const, posts: notes, href: '/lab/notes/' },
  { key: 'journal' as const, posts: journal, href: '/lab/journal/' },
];
---

<BaseLayout title="Growth Lab" section="lab">
  <div class="lab-w">

    <!-- Hero (compact, no graph) -->
    <section class="lab-hero">
      <h1 class="lab-hero__title" data-copy-zh="把增长拆成结构，再把结构变成执行。" data-copy-en="Break growth into structure, then turn structure into execution.">
        把增长拆成结构，再把结构变成执行。
      </h1>
      <p class="lab-hero__desc" data-copy-zh="方法框架、真实拆解、正在形成中的研究线索。不是信息流。" data-copy-en="Frameworks, real teardowns, and research threads. Not a content feed.">
        方法框架、真实拆解、正在形成中的研究线索。不是信息流。
      </p>
      <div class="lab-hero__stats">
        <span><strong>{allPosts.length}</strong> <span data-copy-zh="篇文章" data-copy-en="articles">篇文章</span></span>
        <span><strong>{totalTags}</strong> <span data-copy-zh="个标签" data-copy-en="tags">个标签</span></span>
      </div>
    </section>

    <!-- Content: clusters + sticky sidebar graph -->
    <div class="lab-content">
      <div class="lab-clusters">
        {clusters.map((cluster) => {
          const meta = categoryArchiveMeta[cluster.key];
          return cluster.posts.length > 0 && (
            <TopicCluster
              id={cluster.key}
              eyebrow={meta.eyebrow}
              titleZh={zh.category[cluster.key].label}
              titleEn={en.category[cluster.key].label}
              descZh={zh.category[cluster.key].desc}
              descEn={en.category[cluster.key].desc}
              posts={cluster.posts}
              href={cluster.href}
              linkLabelZh={`查看全部${zh.category[cluster.key].label}`}
              linkLabelEn={`View all ${en.category[cluster.key].label}`}
            />
          );
        })}
      </div>
      <aside class="lab-sidebar">
        <div class="lab-sidebar__sticky">
          <div class="lab-sidebar__label">
            <span data-lang="zh">知识地图</span>
            <span data-lang="en">Knowledge Map</span>
          </div>
          <KnowledgeGraph posts={allPosts} />
        </div>
      </aside>
    </div>

  </div>
</BaseLayout>
