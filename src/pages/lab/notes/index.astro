---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/lab.css';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { categoryArchiveMeta } from '../../../lib/archive';

const posts = (await getCollection('posts'))
  .filter((p) => p.data.category === 'notes' && !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const meta = categoryArchiveMeta.notes;
---

<BaseLayout title={meta.title} description={meta.intro} section="lab">
  <div class="max-w-[960px] mx-auto px-6">
    <section class="pt-12 sm:pt-16 pb-6">
      <div class="label mb-4">{meta.eyebrow} · {posts.length}</div>
      <h1 class="text-[clamp(1.75rem,4vw,2.5rem)] font-bold tracking-[-0.03em] leading-tight mb-3">{meta.title}</h1>
      <p class="text-[15px] text-[var(--text-2)] leading-relaxed max-w-[540px]">{meta.intro}</p>
    </section>
    <div class="border-t border-[var(--border)]"></div>
    <section class="py-8 pb-20">
      {posts.length > 0 ? (
        <div class="article-list">
          {posts.map((post) => (
            <ArticleCard title={post.data.title} description={post.data.description} category={post.data.category}
              tags={post.data.tags} date={post.data.date} slug={post.id} body={post.body || ''} />
          ))}
        </div>
      ) : (
        <p class="text-[15px] text-[var(--text-2)] py-8">{meta.empty}</p>
      )}
    </section>
  </div>
</BaseLayout>
