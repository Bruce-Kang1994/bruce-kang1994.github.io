---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home.css';
import {
  profile, metrics, endorsements, education, now,
  sideProjects, methodAssets, experiences, contact,
} from '../data/siteData';

const structuredData = [
  {
    '@context': 'https://schema.org', '@type': 'Person',
    name: '康鑫', alternateName: 'Bruce Kang',
    url: profile.siteUrl, jobTitle: 'Product Manager',
    description: profile.bio.en,
    sameAs: [contact.github],
    alumniOf: [
      { '@type': 'CollegeOrUniversity', name: 'Tianjin University' },
      { '@type': 'CollegeOrUniversity', name: 'Universiti Sains Malaysia' },
    ],
  },
];

const pressItems = endorsements.filter(e => e.href);
---

<BaseLayout
  title="Bruce Kang｜Product Manager · PostMem Co-Founder"
  description="5 年 B 端产品经验，现在全职做 PostMem。真实项目结果、公开方法论资产与独立产品实践。"
  section="home"
  structuredData={structuredData}
>

  <!-- ══════════ HERO ══════════ -->
  <section class="hero">
    <div class="wrap">
      <div class="hero__name">Bruce Kang</div>
      <div class="hero__roles">
        <span class="hero__role">
          <span data-lang="zh">产品经理</span><span data-lang="en">Product Manager</span>
        </span>
        <span class="hero__role-sep"></span>
        <span class="hero__role">PostMem Co-Founder</span>
      </div>
      <h1 class="hero__title">
        <span data-lang="zh">{profile.heroTitle.zh}</span>
        <span data-lang="en">{profile.heroTitle.en}</span>
      </h1>
      <p class="hero__bio">
        <span data-lang="zh">{profile.bio.zh}</span>
        <span data-lang="en">{profile.bio.en}</span>
      </p>

      <div class="metrics" data-reveal>
        {metrics.map((m) => (
          <div class="metric">
            <div class="metric__val">{m.value}</div>
            <div class="metric__label">
              <span data-lang="zh">{m.label.zh}</span><span data-lang="en">{m.label.en}</span>
            </div>
            <div class="metric__detail">
              <span data-lang="zh">{m.detail.zh}</span><span data-lang="en">{m.detail.en}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════ PRESS ══════════ -->
  <div class="press-bar">
    <div class="wrap">
      <div class="press-bar__inner">
        <span class="press-bar__label">
          <span data-lang="zh">媒体报道</span><span data-lang="en">Press</span>
        </span>
        {pressItems.map((e) => (
          <a href={e.href} target="_blank" rel="noopener" class="press-chip">
            <span data-lang="zh">{e.label.zh}</span><span data-lang="en">{e.label.en}</span> ↗
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ══════════ NOW ══════════ -->
  <section id="now" class="sec">
    <div class="wrap">
      <div class="sec__label">Now</div>
      <div class="sec__title">
        <span data-lang="zh">正在做的事</span><span data-lang="en">What I'm working on</span>
      </div>
      <div class="now-card" data-reveal>
        <div class="now-card__header">
          <div>
            <div class="now-card__title">
              {now.title}
              <span class="badge badge--live" style="margin-left: 0.5rem; vertical-align: middle;">{now.role.zh}</span>
            </div>
            <div class="now-card__tagline">
              <span data-lang="zh">{now.tagline.zh}</span><span data-lang="en">{now.tagline.en}</span>
            </div>
          </div>
          <a href={now.href} target="_blank" rel="noopener" class="now-card__link">
            postmem.com ↗
          </a>
        </div>
        <div class="now-card__body">
          <span data-lang="zh">{now.description.zh}</span><span data-lang="en">{now.description.en}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ WORK ══════════ -->
  <section id="work" class="sec sec--alt">
    <div class="wrap">
      <div class="sec__label">
        <span data-lang="zh">作品</span><span data-lang="en">Work</span>
      </div>

      <div class="sec__title">
        <span data-lang="zh">方法论资产</span><span data-lang="en">Methodology Assets</span>
      </div>
      <div class="sec__desc">
        <span data-lang="zh">增长和 SEO 的实践沉淀，可直接查看的公开站点。</span>
        <span data-lang="en">Growth and SEO practice distilled into public, browsable sites.</span>
      </div>

      <div class="grid-2" data-reveal>
        {methodAssets.map((a) => (
          <a href={a.href} class="card">
            <div class="card__header">
              <span class="card__title">{a.title}</span>
              <span class="badge badge--published">
                <span data-lang="zh">{a.status.zh}</span><span data-lang="en">{a.status.en}</span>
              </span>
            </div>
            <div class="card__desc">
              <span data-lang="zh">{a.tagline.zh}</span><span data-lang="en">{a.tagline.en}</span>
            </div>
            <div class="card__meta">
              <span class="card__link">
                <span data-lang="zh">查看 →</span><span data-lang="en">View →</span>
              </span>
            </div>
          </a>
        ))}
      </div>

      <div style="margin-top: 2.5rem;">
        <div class="sec__title">
          <span data-lang="zh">独立项目</span><span data-lang="en">Side Projects</span>
        </div>
        <div class="sec__desc">
          <span data-lang="zh">从想法到上线的完整实践。</span>
          <span data-lang="en">End-to-end practice from idea to launch.</span>
        </div>
      </div>

      <div class="grid-2" data-reveal>
        {sideProjects.map((p) => (
          <div class="card">
            <div class="card__header">
              <span class="card__title">{p.title}</span>
              <span class={`badge badge--${p.statusType}`}>
                <span data-lang="zh">{p.status.zh}</span><span data-lang="en">{p.status.en}</span>
              </span>
            </div>
            <div class="card__desc">
              <span data-lang="zh">{p.tagline.zh}</span><span data-lang="en">{p.tagline.en}</span>
            </div>
            <div class="card__meta">
              {p.stack}
              {p.href && (
                <span>
                  <span style="margin: 0 0.375rem; color: var(--home-border);">|</span>
                  <a href={p.href} target="_blank" rel="noopener" class="card__link">
                    <span data-lang="zh">查看 ↗</span><span data-lang="en">View ↗</span>
                  </a>
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════ EXPERIENCE ══════════ -->
  <section id="experience" class="sec">
    <div class="wrap">
      <div class="sec__label">
        <span data-lang="zh">经历</span><span data-lang="en">Experience</span>
      </div>
      <div class="sec__title">
        <span data-lang="zh">职业背景</span><span data-lang="en">Career</span>
      </div>
      <div class="sec__desc">
        <span data-lang="zh">5 年 B 端产品经验，独立负责过 3 条产品线从 0 到 1。</span>
        <span data-lang="en">Five years of B2B product experience, having independently led three product lines from zero to one.</span>
      </div>

      <div data-reveal>
        {experiences.map((exp) => (
          <div class="tl-item">
            <div class="tl-period">{exp.period}</div>
            <div>
              <div>
                <span class="tl-company">
                  <span data-lang="zh">{exp.company.zh}</span><span data-lang="en">{exp.company.en}</span>
                </span>
                <span class="tl-role">
                  <span data-lang="zh">{exp.role.zh}</span><span data-lang="en">{exp.role.en}</span>
                </span>
              </div>
              <div class="tl-desc">
                <span data-lang="zh">{exp.description.zh}</span><span data-lang="en">{exp.description.en}</span>
              </div>
              <div class="tl-highlights" data-lang="zh">
                {exp.highlights.zh.map((h) => (
                  <div class="tl-highlight">{h}</div>
                ))}
              </div>
              <div class="tl-highlights" data-lang="en">
                {exp.highlights.en.map((h) => (
                  <div class="tl-highlight">{h}</div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
