---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home.css';
import {
  profile, metrics, now, methodAssets,
  experienceSummary, experiences, contact,
} from '../data/siteData';

const structuredData = [
  {
    '@context': 'https://schema.org', '@type': 'Person',
    name: '康鑫', alternateName: 'Bruce Kang',
    url: profile.siteUrl, jobTitle: 'Growth Practitioner',
    description: profile.bio.en,
    sameAs: [contact.github],
    alumniOf: [
      { '@type': 'CollegeOrUniversity', name: 'Tianjin University' },
      { '@type': 'CollegeOrUniversity', name: 'Universiti Sains Malaysia' },
    ],
  },
];
---

<BaseLayout
  title="Bruce Kang｜Growth Practitioner · Building PostMem"
  description="在真实产品上做增长，把过程写成方法论。SEO 体系、投放策略、用户研究——不是理论，是正在执行的东西。"
  section="home"
  structuredData={structuredData}
>

  <!-- ══════════ HERO ══════════ -->
  <section class="hero">
    <div class="wrap">
      <div class="hero__label">
        <span data-lang="zh">{profile.label.zh}</span>
        <span data-lang="en">{profile.label.en}</span>
      </div>
      <h1 class="hero__title">
        <span data-lang="zh">{profile.heroTitle.zh}</span>
        <span data-lang="en">{profile.heroTitle.en}</span>
      </h1>
      <p class="hero__bio">
        <span data-lang="zh">{profile.bio.zh}</span>
        <span data-lang="en">{profile.bio.en}</span>
      </p>

      <div class="hero__ctas">
        <a href="/lab/" class="hero__cta hero__cta--primary">
          <span data-lang="zh">看方法论 →</span>
          <span data-lang="en">Read the playbook →</span>
        </a>
        <a href="/postmem/" class="hero__cta hero__cta--secondary">
          <span data-lang="zh">看 SEO 实战 →</span>
          <span data-lang="en">See SEO in action →</span>
        </a>
      </div>

      <div class="metrics" data-reveal>
        {metrics.map((m) => (
          <div class="metric">
            <div class="metric__val">{m.value}</div>
            <div class="metric__label">
              <span data-lang="zh">{m.label.zh}</span><span data-lang="en">{m.label.en}</span>
            </div>
            <div class="metric__detail">
              <span data-lang="zh">{m.detail.zh}</span><span data-lang="en">{m.detail.en}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════ NOW: GROWTH PRACTICE ══════════ -->
  <section id="now" class="sec">
    <div class="wrap">
      <div class="sec__label">
        <span data-lang="zh">正在做的增长实践</span><span data-lang="en">Current Growth Practice</span>
      </div>
      <div class="now-card" data-reveal>
        <div class="now-card__header">
          <div>
            <div class="now-card__title">{now.title}</div>
            <div class="now-card__tagline">
              <span data-lang="zh">{now.tagline.zh}</span><span data-lang="en">{now.tagline.en}</span>
            </div>
          </div>
          <a href={now.href} target="_blank" rel="noopener" class="now-card__link">
            postmem.com ↗
          </a>
        </div>
        <div class="now-card__practices">
          <div data-lang="zh">
            {now.practices.zh.map((p) => (
              <div class="now-card__practice">{p}</div>
            ))}
          </div>
          <div data-lang="en">
            {now.practices.en.map((p) => (
              <div class="now-card__practice">{p}</div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ TWO ASSETS ══════════ -->
  <section id="work" class="sec sec--alt">
    <div class="wrap">
      <div class="sec__label">
        <span data-lang="zh">公开资产</span><span data-lang="en">Public Assets</span>
      </div>
      <div class="sec__title">
        <span data-lang="zh">Lab 是思考，SEO 是执行。同一个人，同一条线。</span>
        <span data-lang="en">Lab is thinking, SEO is doing. Same person, same thread.</span>
      </div>

      <div class="grid-2" data-reveal>
        {methodAssets.map((a) => (
          <a href={a.href} class="card">
            <div class="card__header">
              <span class="card__title">{a.title}</span>
              <span class="badge badge--published">{a.count}</span>
            </div>
            <div class="card__subtitle">
              <span data-lang="zh">{a.subtitle.zh}</span><span data-lang="en">{a.subtitle.en}</span>
            </div>
            <div class="card__desc">
              <span data-lang="zh">{a.tagline.zh}</span><span data-lang="en">{a.tagline.en}</span>
            </div>
            <div class="card__meta">
              <span class="card__link">
                <span data-lang="zh">查看 →</span><span data-lang="en">View →</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════ EXPERIENCE (collapsed) ══════════ -->
  <section id="experience" class="sec">
    <div class="wrap">
      <div class="sec__label">
        <span data-lang="zh">背景</span><span data-lang="en">Background</span>
      </div>
      <p class="exp-summary">
        <span data-lang="zh">{experienceSummary.zh}</span>
        <span data-lang="en">{experienceSummary.en}</span>
      </p>

      <details class="exp-details" data-reveal>
        <summary class="exp-toggle">
          <span data-lang="zh">展开看详细经历 ↓</span>
          <span data-lang="en">Show full experience ↓</span>
        </summary>
        <div class="exp-list">
          {experiences.map((exp) => (
            <div class="tl-item">
              <div>
                <span class="tl-company">
                  <span data-lang="zh">{exp.company.zh}</span><span data-lang="en">{exp.company.en}</span>
                </span>
                <span class="tl-role">
                  <span data-lang="zh">{exp.role.zh}</span><span data-lang="en">{exp.role.en}</span>
                </span>
                <span class="tl-period">{exp.period}</span>
              </div>
              <div class="tl-desc">
                <span data-lang="zh">{exp.description.zh}</span><span data-lang="en">{exp.description.en}</span>
              </div>
              <div class="tl-highlights" data-lang="zh">
                {exp.highlights.zh.map((h) => (
                  <div class="tl-highlight">{h}</div>
                ))}
              </div>
              <div class="tl-highlights" data-lang="en">
                {exp.highlights.en.map((h) => (
                  <div class="tl-highlight">{h}</div>
                ))}
              </div>
              {'pressLinks' in exp && exp.pressLinks && (
                <div class="tl-press">
                  {exp.pressLinks.map((link) => (
                    <a href={link.href} target="_blank" rel="noopener" class="tl-press__link">
                      <span data-lang="zh">{link.label.zh}</span><span data-lang="en">{link.label.en}</span> ↗
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </details>
    </div>
  </section>

</BaseLayout>
