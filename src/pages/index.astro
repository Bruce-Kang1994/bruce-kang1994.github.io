---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home.css';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { profile, now, contact } from '../data/siteData';
import { translations } from '../lib/i18n';

// ── Data ──
const labPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
const postmemPosts = (await getCollection('postmem')).filter((p) => !p.data.draft);

const featuredPosts = labPosts
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const latestPosts = labPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

// Category counts
const catCount = (cat: string) => labPosts.filter((p) => p.data.category === cat).length;

const zh = translations.zh;
const en = translations.en;

// Knowledge map data
const knowledgeMap = [
  {
    count: catCount('frameworks'),
    titleZh: zh.category.frameworks.label,
    titleEn: en.category.frameworks.label,
    descZh: zh.category.frameworks.desc,
    descEn: en.category.frameworks.desc,
    href: '/lab/frameworks/',
  },
  {
    count: catCount('case-studies'),
    titleZh: zh.category['case-studies'].label,
    titleEn: en.category['case-studies'].label,
    descZh: zh.category['case-studies'].desc,
    descEn: en.category['case-studies'].desc,
    href: '/lab/case-studies/',
  },
  {
    count: catCount('dialogues'),
    titleZh: zh.category.dialogues.label,
    titleEn: en.category.dialogues.label,
    descZh: zh.category.dialogues.desc,
    descEn: en.category.dialogues.desc,
    href: '/lab/dialogues/',
  },
  {
    count: catCount('notes'),
    titleZh: zh.category.notes.label,
    titleEn: en.category.notes.label,
    descZh: zh.category.notes.desc,
    descEn: en.category.notes.desc,
    href: '/lab/notes/',
  },
  {
    count: catCount('journal'),
    titleZh: zh.category.journal.label,
    titleEn: en.category.journal.label,
    descZh: zh.category.journal.desc,
    descEn: en.category.journal.desc,
    href: '/lab/journal/',
  },
  {
    count: postmemPosts.length,
    titleZh: 'PostMem SEO',
    titleEn: 'PostMem SEO',
    descZh: '围绕真实用户需求搭建的 SEO/GEO 内容体系',
    descEn: 'SEO/GEO content system built from real user needs',
    href: '/postmem/',
  },
];

const structuredData = [
  {
    '@context': 'https://schema.org', '@type': 'Person',
    name: '康鑫', alternateName: 'Bruce Kang',
    url: profile.siteUrl, jobTitle: 'Growth Practitioner',
    description: profile.bio.en,
    sameAs: [contact.github],
    alumniOf: [
      { '@type': 'CollegeOrUniversity', name: 'Tianjin University' },
      { '@type': 'CollegeOrUniversity', name: 'Universiti Sains Malaysia' },
    ],
  },
];
---

<BaseLayout
  title="Bruce Kang｜Growth Practitioner · Building PostMem"
  description="在真实产品上做增长，把过程写成方法论。SEO 体系、投放策略、用户研究——不是理论，是正在执行的东西。"
  section="home"
  structuredData={structuredData}
>

  <!-- ═══ 1. METHODOLOGY HERO ═══ -->
  <section class="hero">
    <div class="hero__inner">
      <h1 class="hero__title">
        <span data-lang="zh">{profile.heroTitle.zh}</span>
        <span data-lang="en">{profile.heroTitle.en}</span>
      </h1>
      <p class="hero__tagline">
        <span data-lang="zh">{profile.tagline.zh}</span>
        <span data-lang="en">{profile.tagline.en}</span>
      </p>
      <div class="hero__ctas">
        <a href="/lab/" class="hero__cta hero__cta--primary">
          <span data-lang="zh">Growth Lab →</span>
          <span data-lang="en">Growth Lab →</span>
        </a>
        <a href="/postmem/" class="hero__cta hero__cta--secondary">
          <span data-lang="zh">PostMem SEO →</span>
          <span data-lang="en">PostMem SEO →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ 2. FEATURED METHODOLOGY ═══ -->
  <section class="sec">
    <div class="page-w">
      <div class="sec__label">
        <span data-lang="zh">{zh.home.featured}</span>
        <span data-lang="en">{en.home.featured}</span>
      </div>
      <div class="featured-list" data-reveal>
        {featuredPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            tags={post.data.tags}
            date={post.data.date}
            slug={post.id}
            body={post.body || ''}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ 3. KNOWLEDGE MAP ═══ -->
  <section class="sec">
    <div class="page-w">
      <div class="sec__label">
        <span data-lang="zh">{zh.home.knowledgeMap}</span>
        <span data-lang="en">{en.home.knowledgeMap}</span>
      </div>
      <div class="knowledge-map" data-reveal>
        {knowledgeMap.map((item) => (
          <a href={item.href} class="km-card">
            <div class="km-card__count">{item.count}</div>
            <div class="km-card__body">
              <h3 class="km-card__title">
                <span data-lang="zh">{item.titleZh}</span>
                <span data-lang="en">{item.titleEn}</span>
              </h3>
              <p class="km-card__desc">
                <span data-lang="zh">{item.descZh}</span>
                <span data-lang="en">{item.descEn}</span>
              </p>
            </div>
            <span class="km-card__arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ 4. CURRENT PRACTICE ═══ -->
  <section class="sec">
    <div class="page-w">
      <div class="sec__label">
        <span data-lang="zh">{zh.home.currentPractice}</span>
        <span data-lang="en">{en.home.currentPractice}</span>
      </div>
      <a href={now.href} target="_blank" rel="noopener" class="now-card" data-reveal>
        <div class="now-card__body">
          <h2 class="now-card__title">{now.title}</h2>
          <p class="now-card__tagline">
            <span data-lang="zh">{now.tagline.zh}</span>
            <span data-lang="en">{now.tagline.en}</span>
          </p>
        </div>
        <span class="now-card__link">postmem.com ↗</span>
      </a>
    </div>
  </section>

  <!-- ═══ 5. LATEST ARTICLES ═══ -->
  <section class="sec">
    <div class="page-w">
      <div class="sec__label">
        <span data-lang="zh">{zh.home.latest}</span>
        <span data-lang="en">{en.home.latest}</span>
      </div>
      <div class="latest-feed" data-reveal>
        {latestPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            tags={post.data.tags}
            date={post.data.date}
            slug={post.id}
            body={post.body || ''}
          />
        ))}
      </div>
      <a href="/lab/" class="sec__view-all">
        <span data-lang="zh">{zh.home.viewAll} →</span>
        <span data-lang="en">{en.home.viewAll} →</span>
      </a>
    </div>
  </section>

</BaseLayout>
