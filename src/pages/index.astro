---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home.css';
import {
  profile, metrics, now, methodAssets,
  experienceSummary, experiences, contact,
} from '../data/siteData';

const structuredData = [
  {
    '@context': 'https://schema.org', '@type': 'Person',
    name: '康鑫', alternateName: 'Bruce Kang',
    url: profile.siteUrl, jobTitle: 'Growth Practitioner',
    description: profile.bio.en,
    sameAs: [contact.github],
    alumniOf: [
      { '@type': 'CollegeOrUniversity', name: 'Tianjin University' },
      { '@type': 'CollegeOrUniversity', name: 'Universiti Sains Malaysia' },
    ],
  },
];
---

<BaseLayout
  title="Bruce Kang｜Growth Practitioner · Building PostMem"
  description="在真实产品上做增长，把过程写成方法论。SEO 体系、投放策略、用户研究——不是理论，是正在执行的东西。"
  section="home"
  structuredData={structuredData}
>

  <!-- ══════════ HERO ══════════ -->
  <section class="hero">
    <div class="hero__aurora"></div>
    <div class="wrap">
      <div class="hero__label">
        <span data-lang="zh">{profile.label.zh}</span>
        <span data-lang="en">{profile.label.en}</span>
      </div>
      <h1 class="hero__title">
        <span data-lang="zh">{profile.heroTitle.zh}</span>
        <span data-lang="en">{profile.heroTitle.en}</span>
      </h1>
      <p class="hero__bio">
        <span data-lang="zh">{profile.bio.zh}</span>
        <span data-lang="en">{profile.bio.en}</span>
      </p>

      <div class="hero__ctas">
        <a href="/lab/" class="hero__cta hero__cta--primary">
          <span data-lang="zh">看方法论 →</span>
          <span data-lang="en">Read the playbook →</span>
        </a>
        <a href="/postmem/" class="hero__cta hero__cta--secondary">
          <span data-lang="zh">看 SEO 实战 →</span>
          <span data-lang="en">See SEO in action →</span>
        </a>
      </div>

      <div class="metrics" data-reveal>
        {metrics.map((m, i) => (
          <div class="metric" style={`--delay: ${i * 80}ms`}>
            <div class="metric__val">{m.value}</div>
            <div class="metric__label">
              <span data-lang="zh">{m.label.zh}</span><span data-lang="en">{m.label.en}</span>
            </div>
            <div class="metric__detail">
              <span data-lang="zh">{m.detail.zh}</span><span data-lang="en">{m.detail.en}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════ NOW: GROWTH PRACTICE ══════════ -->
  <section id="now" class="sec">
    <div class="wrap">
      <div class="sec__label">
        <span data-lang="zh">正在做的增长实践</span><span data-lang="en">Current Growth Practice</span>
      </div>
      <div class="now-card" data-reveal>
        <div class="now-card__header">
          <div>
            <div class="now-card__title">{now.title}</div>
            <div class="now-card__tagline">
              <span data-lang="zh">{now.tagline.zh}</span><span data-lang="en">{now.tagline.en}</span>
            </div>
          </div>
          <a href={now.href} target="_blank" rel="noopener" class="now-card__link">
            postmem.com ↗
          </a>
        </div>
        <div class="now-card__practices">
          <div data-lang="zh">
            {now.practices.zh.map((p) => (
              <div class="now-card__practice">{p}</div>
            ))}
          </div>
          <div data-lang="en">
            {now.practices.en.map((p) => (
              <div class="now-card__practice">{p}</div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ TWO ASSETS ══════════ -->
  <section id="work" class="sec sec--alt">
    <div class="wrap">
      <div class="sec__label">
        <span data-lang="zh">公开资产</span><span data-lang="en">Public Assets</span>
      </div>
      <div class="sec__title">
        <span data-lang="zh">Lab 是思考，SEO 是执行。同一个人，同一条线。</span>
        <span data-lang="en">Lab is thinking, SEO is doing. Same person, same thread.</span>
      </div>

      <div class="grid-2" data-reveal>
        {methodAssets.map((a, i) => (
          <a href={a.href} class="card" style={`--delay: ${i * 120}ms`}>
            <div class="card__header">
              <span class="card__title">{a.title}</span>
              <span class="badge badge--published">{a.count}</span>
            </div>
            <div class="card__subtitle">
              <span data-lang="zh">{a.subtitle.zh}</span><span data-lang="en">{a.subtitle.en}</span>
            </div>
            <div class="card__desc">
              <span data-lang="zh">{a.tagline.zh}</span><span data-lang="en">{a.tagline.en}</span>
            </div>
            <div class="card__meta">
              <span class="card__link">
                <span data-lang="zh">查看 →</span><span data-lang="en">View →</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════ EXPERIENCE (collapsed) ══════════ -->
  <section id="experience" class="sec">
    <div class="wrap">
      <div class="sec__label">
        <span data-lang="zh">背景</span><span data-lang="en">Background</span>
      </div>
      <p class="exp-summary">
        <span data-lang="zh">{experienceSummary.zh}</span>
        <span data-lang="en">{experienceSummary.en}</span>
      </p>

      <details class="exp-details" data-reveal>
        <summary class="exp-toggle">
          <span data-lang="zh">展开看详细经历 ↓</span>
          <span data-lang="en">Show full experience ↓</span>
        </summary>
        <div class="exp-list">
          {experiences.map((exp) => (
            <div class="tl-item">
              <div>
                <span class="tl-company">
                  <span data-lang="zh">{exp.company.zh}</span><span data-lang="en">{exp.company.en}</span>
                </span>
                <span class="tl-role">
                  <span data-lang="zh">{exp.role.zh}</span><span data-lang="en">{exp.role.en}</span>
                </span>
                <span class="tl-period">{exp.period}</span>
              </div>
              <div class="tl-desc">
                <span data-lang="zh">{exp.description.zh}</span><span data-lang="en">{exp.description.en}</span>
              </div>
              <div class="tl-highlights" data-lang="zh">
                {exp.highlights.zh.map((h) => (
                  <div class="tl-highlight">{h}</div>
                ))}
              </div>
              <div class="tl-highlights" data-lang="en">
                {exp.highlights.en.map((h) => (
                  <div class="tl-highlight">{h}</div>
                ))}
              </div>
              {'pressLinks' in exp && exp.pressLinks && (
                <div class="tl-press">
                  {exp.pressLinks.map((link) => (
                    <a href={link.href} target="_blank" rel="noopener" class="tl-press__link">
                      <span data-lang="zh">{link.label.zh}</span><span data-lang="en">{link.label.en}</span> ↗
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </details>
    </div>
  </section>

  <!-- ══════════ GSAP Animations ══════════ -->
  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    // Respect reduced motion
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) {
      document.querySelectorAll('.hero__label, .hero__title, .hero__bio, .hero__ctas')
        .forEach(el => (el as HTMLElement).style.visibility = 'visible');
    }

    if (!prefersReduced) {
      // ── Hero entrance timeline ──
      const heroTl = gsap.timeline({ delay: 0.15 });

      // Label: slide in from left with a blur
      heroTl.fromTo('.hero__label',
        { autoAlpha: 0, x: -30, filter: 'blur(8px)' },
        { autoAlpha: 1, x: 0, filter: 'blur(0px)', duration: 0.6, ease: 'power3.out' }
      );

      // Title: split into words, each word pops in
      const titleEl = document.querySelector('.hero__title');
      if (titleEl) {
        // Get all visible span[data-lang] children
        const langSpans = titleEl.querySelectorAll('span[data-lang]');
        langSpans.forEach(span => {
          const text = span.textContent || '';
          // Split by characters for Chinese, words for English
          const lang = span.getAttribute('data-lang');
          let parts: string[];
          if (lang === 'en') {
            parts = text.split(/(\s+)/); // preserve spaces
          } else {
            parts = text.split('');
          }
          span.innerHTML = parts.map(p =>
            p.trim() === '' ? p : `<span class="char" style="display:inline-block">${p}</span>`
          ).join('');
        });

        heroTl.fromTo('.hero__title .char',
          { autoAlpha: 0, y: 40, rotateX: -90, filter: 'blur(6px)' },
          {
            autoAlpha: 1, y: 0, rotateX: 0, filter: 'blur(0px)',
            duration: 0.5, stagger: 0.03, ease: 'back.out(1.7)'
          },
          '-=0.2'
        );

        // Make title visible (container)
        heroTl.set('.hero__title', { visibility: 'visible' }, 0);
      }

      // Bio: fade up
      heroTl.fromTo('.hero__bio',
        { autoAlpha: 0, y: 20 },
        { autoAlpha: 1, y: 0, duration: 0.6, ease: 'power2.out' },
        '-=0.2'
      );

      // CTAs: pop in with scale bounce
      heroTl.fromTo('.hero__cta',
        { autoAlpha: 0, y: 20, scale: 0.8 },
        {
          autoAlpha: 1, y: 0, scale: 1,
          duration: 0.5, stagger: 0.12, ease: 'back.out(2)'
        },
        '-=0.3'
      );
      // Make ctas container visible
      heroTl.set('.hero__ctas', { visibility: 'visible' }, 0);

      // ── Metrics: count-up numbers + stagger in ──
      const metricsEl = document.querySelector('.metrics');
      if (metricsEl) {
        const metricItems = metricsEl.querySelectorAll('.metric');

        ScrollTrigger.create({
          trigger: metricsEl,
          start: 'top 85%',
          once: true,
          onEnter: () => {
            gsap.fromTo(metricItems,
              { autoAlpha: 0, y: 30, scale: 0.9 },
              {
                autoAlpha: 1, y: 0, scale: 1,
                duration: 0.5, stagger: 0.1, ease: 'back.out(1.4)'
              }
            );

            // Animate numbers (count up effect)
            metricItems.forEach(item => {
              const valEl = item.querySelector('.metric__val');
              if (!valEl) return;
              const finalText = valEl.textContent || '';
              const numMatch = finalText.match(/[\d.]+/);
              if (!numMatch) return;

              const finalNum = parseFloat(numMatch[0]);
              const prefix = finalText.slice(0, finalText.indexOf(numMatch[0]));
              const suffix = finalText.slice(finalText.indexOf(numMatch[0]) + numMatch[0].length);
              const isFloat = numMatch[0].includes('.');
              const decimals = isFloat ? (numMatch[0].split('.')[1] || '').length : 0;

              const counter = { val: 0 };
              gsap.to(counter, {
                val: finalNum,
                duration: 1.2,
                delay: 0.3,
                ease: 'power2.out',
                onUpdate: () => {
                  valEl.textContent = prefix + (isFloat ? counter.val.toFixed(decimals) : Math.round(counter.val).toString()) + suffix;
                }
              });
            });
          }
        });
      }

      // ── Now card: slide in from bottom with rotation ──
      gsap.fromTo('.now-card',
        { autoAlpha: 0, y: 60, rotateX: -8 },
        {
          autoAlpha: 1, y: 0, rotateX: 0,
          duration: 0.8, ease: 'power3.out',
          scrollTrigger: { trigger: '.now-card', start: 'top 85%', once: true }
        }
      );

      // ── Cards: stagger from alternate sides ──
      const cards = document.querySelectorAll('.grid-2 .card');
      cards.forEach((card, i) => {
        const fromX = i % 2 === 0 ? -60 : 60;
        gsap.fromTo(card,
          { autoAlpha: 0, x: fromX, rotateY: i % 2 === 0 ? -10 : 10 },
          {
            autoAlpha: 1, x: 0, rotateY: 0,
            duration: 0.7, ease: 'power3.out',
            scrollTrigger: { trigger: card, start: 'top 88%', once: true },
            delay: i * 0.15
          }
        );
      });

      // ── Experience section ──
      gsap.fromTo('.exp-details',
        { autoAlpha: 0, y: 40 },
        {
          autoAlpha: 1, y: 0,
          duration: 0.6, ease: 'power2.out',
          scrollTrigger: { trigger: '.exp-details', start: 'top 85%', once: true }
        }
      );

      // ── Section labels: slide in from left ──
      document.querySelectorAll('.sec__label').forEach(label => {
        gsap.fromTo(label,
          { autoAlpha: 0, x: -40 },
          {
            autoAlpha: 1, x: 0,
            duration: 0.5, ease: 'power2.out',
            scrollTrigger: { trigger: label, start: 'top 90%', once: true }
          }
        );
      });

      document.querySelectorAll('.sec__title').forEach(title => {
        gsap.fromTo(title,
          { autoAlpha: 0, y: 20 },
          {
            autoAlpha: 1, y: 0,
            duration: 0.6, ease: 'power2.out',
            scrollTrigger: { trigger: title, start: 'top 88%', once: true }
          }
        );
      });
    }
  </script>

</BaseLayout>
